{
  "name": "appspirin",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "postinstall": "patch-package"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|@nozbe/watermelondb|react-native-paper)"
    ],
    "moduleNameMapper": {
      "^expo/src/winter$": "<rootDir>/__mocks__/expoWinter.js",
      "^expo/src/winter/(.*)$": "<rootDir>/__mocks__/expoWinter.js",
      "^@components/(.*)$": "<rootDir>/src/components/$1",
      "^@screens/(.*)$": "<rootDir>/src/screens/$1",
      "^@db/(.*)$": "<rootDir>/src/db/$1",
      "^@theme/(.*)$": "<rootDir>/src/theme/$1",
      "^@services/(.*)$": "<rootDir>/src/services/$1",
      "^@utils/(.*)$": "<rootDir>/src/utils/$1",
      "^@hooks/(.*)$": "<rootDir>/src/hooks/$1",
      "^@constants/(.*)$": "<rootDir>/src/constants/$1",
      "^@providers/(.*)$": "<rootDir>/src/providers/$1",
      "^@navigation/(.*)$": "<rootDir>/src/navigation/$1"
    }
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@nozbe/watermelondb": "^0.28.0",
    "@nozbe/with-observables": "^1.6.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/drawer": "^7.9.4",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "expo": "~55.0.5",
    "expo-camera": "~55.0.9",
    "expo-local-authentication": "~55.0.8",
    "expo-notifications": "~55.0.11",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-keychain": "^10.0.0",
    "react-native-paper": "^5.15.0",
    "react-native-reanimated": "^4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-worklets": "^0.7.2",
    "react-native-worklets-core": "^1.6.3"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "^55.0.10",
    "jest": "~29.7.0",
    "jest-expo": "^55.0.9",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@nozbe/simdjson",
          "@nozbe/watermelondb"
        ],
        "listUnknownPackages": false
      }
    },
    "install": {
      "exclude": [
        "react-native-worklets-core"
      ]
    }
  }
}
